IF
    InParty(Myself)
    Global("ZBNEPHXP","GLOBAL",0)
    Global("ZBNEPH_JOINED_FIRST_TIME","GLOBAL",0)
    XPLT(Player1,880000)
THEN
    RESPONSE #100
    SetGlobal("ZBNEPH_JOINED_FIRST_TIME","GLOBAL",1)
    SetGlobal("ZBNEPHXP","GLOBAL",1)
END

IF
    InParty(Myself)
    Global("ZBNEPHXP","GLOBAL",0)
    Global("ZBNEPH_JOINED_FIRST_TIME","GLOBAL",0)
    XPGT(Player1,900000)
    XPLT(Player1,1100000)
THEN
    RESPONSE #100
    SetGlobal("ZBNEPH_JOINED_FIRST_TIME","GLOBAL",1)
    SetGlobal("ZBNEPHXP","GLOBAL",1)
    AddXPObject("zbneph",120000)
END

